{
  "name": "monomind",
  "version": "1.16.8",
  "description": "Monomind - Enterprise AI agent orchestration for Claude Code. Deploy 60+ specialized agents in coordinated swarms with self-learning, fault-tolerant consensus, vector memory, and MCP integration",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "monomind": "./bin/cli.js"
  },
  "homepage": "https://github.com/monoes/monomind#readme",
  "bugs": {
    "url": "https://github.com/monoes/monomind/issues",
    "email": "support@monoes.me"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/nokhodian"
  },
  "files": [
    "bin/**",
    "packages/@monomind/cli/bin/**",
    "packages/@monomind/cli/dist/**/*.js",
    "packages/@monomind/cli/dist/**/*.mjs",
    "packages/@monomind/cli/dist/**/*.html",
    "packages/@monomind/cli/dist/**/*.json",
    "packages/@monomind/cli/dist/**/*.svg",
    "packages/@monomind/cli/dist/**/*.d.ts",
    "!packages/@monomind/cli/dist/**/*.map",
    "packages/@monomind/cli/bundled-graph/**",
    "packages/@monomind/cli/scripts/**/*.mjs",
    "packages/@monomind/cli/scripts/**/*.js",
    "packages/@monomind/cli/scripts/**/*.sh",
    "packages/@monomind/cli/package.json",
    "scripts/*.mjs",
    "scripts/*.sh",
    "packages/@monomind/guidance/dist/**/*.js",
    "packages/@monomind/guidance/dist/**/*.d.ts",
    "!packages/@monomind/guidance/dist/**/*.map",
    "packages/@monomind/guidance/package.json",
    "packages/@monomind/cli/.claude/**",
    "!packages/@monomind/cli/.claude/**/*.db",
    ".claude-plugin/**",
    ".claude/**",
    "!.claude/**/*.db",
    "!.claude/**/*.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:ts": "cd packages/@monomind/cli && npm run build || true",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:security": "vitest run packages/__tests__/security/",
    "security:audit": "npm audit --audit-level high",
    "security:fix": "npm audit fix",
    "security:test": "npm run test:security",
    "v1:domains": "npm run build:domains",
    "v1:swarm": "npm run start:swarm",
    "v1:security": "npm run security:audit && npm run security:test"
  },
  "dependencies": {
    "semver": "^7.6.0",
    "zod": "^3.22.0",
    "@monoes/monograph": "^1.2.2",
    "@monoes/monobrowse": "^1.0.0"
  },
  "overrides": {
    "hono": ">=4.12.21",
    "ws": ">=8.20.1",
    "axios": ">=1.16.0",
    "qs": ">=6.15.2",
    "esbuild": ">=0.28.1",
    "protobufjs": ">=7.5.8",
    "@protobufjs/utf8": ">=1.1.1",
    "@grpc/grpc-js": ">=1.14.4"
  },
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.21",
      "ws": ">=8.20.1",
      "axios": ">=1.16.0",
      "qs": ">=6.15.2",
      "esbuild": ">=0.28.1",
      "protobufjs": ">=7.5.8",
      "@protobufjs/utf8": ">=1.1.1",
      "@grpc/grpc-js": ">=1.14.4",
      "vite": ">=8.0.16",
      "postcss": ">=8.5.10",
      "fast-uri": ">=3.1.2",
      "form-data": ">=4.0.6",
      "ip-address": ">=10.1.1",
      "js-yaml": ">=4.2.0",
      "undici": ">=7.28.0",
      "http-proxy-middleware": ">=3.0.7",
      "follow-redirects": ">=1.16.0",
      "@anthropic-ai/claude-code": ">=2.1.163",
      "handlebars": ">=4.7.9"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "tree-sitter": "0.22.4",
        "marked": "16",
        "@vitest/coverage-v8": "4.1.8",
        "vitest": "4.1.4",
        "vite": "8"
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/monoes/monomind.git"
  },
  "keywords": [
    "ruvflow",
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "ai-agents",
    "multi-agent",
    "agent-orchestration",
    "swarm-intelligence",
    "swarm",
    "mcp",
    "model-context-protocol",
    "llm",
    "large-language-model",
    "gpt",
    "chatgpt",
    "automation",
    "workflow",
    "orchestration",
    "cli",
    "developer-tools",
    "devtools",
    "coding-assistant",
    "code-generation",
    "enterprise",
    "vector-database",
    "embeddings",
    "machine-learning",
    "neural-network",
    "hive-mind",
    "distributed-systems",
    "consensus",
    "self-learning"
  ],
  "author": {
    "name": "nokhodian",
    "email": "nokhodian@gmail.com",
    "url": "https://github.com/nokhodian"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  }
}
