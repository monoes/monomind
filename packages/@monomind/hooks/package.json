{
  "name": "@monomind/hooks",
  "version": "1.0.0",
  "description": "Hook type definitions, an in-memory HookRegistry/HookExecutor, and a WorkerManager with 15 background workers (performance/health/swarm/git/learning/adr/ddd/security/patterns/cache/progress/map/audit/optimize/consolidate). Not the runtime hook dispatcher \u2014 the live path is .claude/helpers/ (CJS handlers driven by settings.json), which bridges into this package's workers.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "import": "./dist/executor/index.js"
    },
    "./dist/workers/*.js": "./dist/workers/*.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monoes/memory": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "monomind",
    "hooks",
    "daemons",
    "statusline",
    "reasoningbank",
    "mcp",
    "agents"
  ],
  "author": "Monomind Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/monoes/monomind.git",
    "directory": "packages/@monomind/hooks"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
