{
  "name": "@monoes/monomindcli",
  "version": "2.5.1",
  "type": "module",
  "description": "CLI engine for Monomind — an open-source MCP server that extends Claude Code with a codebase knowledge graph (tree-sitter + SQLite), persistent memory, multi-agent task coordination, and session hooks. MIT licensed, fully local.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "cli": "./bin/cli.js",
    "monomind": "./bin/cli.js",
    "monomind-mcp": "./bin/mcp-server.js"
  },
  "homepage": "https://github.com/monoes/monomind#readme",
  "bugs": {
    "url": "https://github.com/monoes/monomind/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/monoes/monomind.git",
    "directory": "packages/@monomind/cli"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "mcp",
    "model-context-protocol",
    "knowledge-graph",
    "tree-sitter",
    "code-analysis",
    "ai-agents",
    "multi-agent",
    "cli",
    "developer-tools",
    "open-source",
    "local-first"
  ],
  "author": {
    "name": "nokhodian",
    "email": "nokhodian@gmail.com",
    "url": "https://github.com/nokhodian"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./monovector": {
      "types": "./dist/src/monovector/index.d.ts",
      "import": "./dist/src/monovector/index.js"
    },
    "./monovector/*": {
      "types": "./dist/src/monovector/*.d.ts",
      "import": "./dist/src/monovector/*.js"
    },
    "./mcp-tools": {
      "types": "./dist/src/mcp-tools/index.d.ts",
      "import": "./dist/src/mcp-tools/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "!dist/**/__tests__/**",
    "bin",
    ".claude",
    "!.claude/**/.monomind/**",
    "!.claude/**/*.lock",
    "!dist/**/.monomind/**",
    "!dist/**/._*",
    "!.claude/agents/generated/**",
    "!.claude/agents/reengineer-squad/**",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && mkdir -p dist/src/browser/dashboard && cp src/browser/dashboard/ui.html dist/src/browser/dashboard/ui.html && mkdir -p dist/src/ui && cp src/ui/dashboard.html src/ui/server.mjs src/ui/collector.mjs src/ui/orgs.html src/ui/orgs-files.js src/ui/sse-manager.mjs src/ui/mastermind-diagram-fallback.html dist/src/ui/ && rm -rf dist/src/ui/data && cp -r src/ui/data dist/src/ui/data",
    "build:loose": "tsc --noEmitOnError false || true && mkdir -p dist/src/browser/dashboard && cp src/browser/dashboard/ui.html dist/src/browser/dashboard/ui.html && mkdir -p dist/src/ui && cp src/ui/dashboard.html src/ui/server.mjs src/ui/collector.mjs src/ui/orgs.html src/ui/orgs-files.js src/ui/sse-manager.mjs src/ui/mastermind-diagram-fallback.html dist/src/ui/ && rm -rf dist/src/ui/data && cp -r src/ui/data dist/src/ui/data",
    "test": "vitest run",
    "test:pattern-store": "npx tsx src/transfer/store/tests/standalone-test.ts",
    "prepublishOnly": "cp ../../../README.md ./README.md",
    "release": "npm version prerelease --preid=alpha && npm run publish:all",
    "publish:all": "./scripts/publish.sh"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.207",
    "@monoes/monobrowse": "^1.0.3",
    "@monoes/monograph": "^1.4.0",
    "@noble/ed25519": "^2.1.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.21.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@monoes/memory": "^1.0.10",
    "@monomind/hooks": "*",
    "@monomind/mcp": "*",
    "@monomind/routing": "*",
    "monofence-ai": "*",
    "sql.js": "^1.14.1"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "overrides": {
    "onnxruntime-node": ">=1.27.0"
  }
}
