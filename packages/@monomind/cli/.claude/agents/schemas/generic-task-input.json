{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "generic-task-input",
  "type": "object",
  "required": ["task"],
  "properties": {
    "task": { "type": "string", "description": "The task description", "minLength": 1, "maxLength": 4000 },
    "context": { "type": "string", "description": "Optional additional context" },
