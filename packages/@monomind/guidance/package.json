{
  "name": "@monomind/guidance",
  "version": "1.0.0",
  "description": "Enforcement gates for Claude Code hooks — destructive-ops detection and secrets scanning",
  "experimental": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./gates": {
      "types": "./dist/gates.d.ts",
      "import": "./dist/gates.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {},
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "monomind",
    "claude-code",
    "claude",
    "anthropic",
    "ai-agent",
    "ai-governance",
    "agent-governance",
    "guidance",
    "control-plane",
    "policy-enforcement",
    "enforcement-gates",
    "proof-chain",
    "trust-system",
    "long-horizon",
    "autonomous-agent",
    "claude-md",
    "CLAUDE.md",
    "memory-governance",
    "adversarial-defense",
    "prompt-injection",
    "wasm",
    "ai-safety",
    "agent-orchestration",
    "multi-agent",
    "code-generation",
    "llm-governance",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Monomind Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/monoes/monomind.git",
    "directory": "packages/@monomind/guidance"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  }
}
