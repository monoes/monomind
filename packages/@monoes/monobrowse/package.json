{
  "name": "@monoes/monobrowse",
  "version": "1.0.2",
  "description": "Native browser automation via Chrome DevTools Protocol — the engine powering monomind browse",
  "type": "module",
  "bin": {
    "monobrowse": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./cli": {
      "types": "./dist/src/cli.d.ts",
      "import": "./dist/src/cli.js"
    },
    "./cli/commands": {
      "types": "./dist/src/cli/commands.d.ts",
      "import": "./dist/src/cli/commands.js"
    },
    "./cli/types": {
      "types": "./dist/src/cli/types.d.ts",
      "import": "./dist/src/cli/types.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/src/browser/dashboard && cp src/browser/dashboard/ui.html dist/src/browser/dashboard/ui.html",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "browser-automation",
    "cdp",
    "chrome-devtools-protocol",
    "monomind",
    "web-scraping",
    "accessibility"
  ],
  "author": {
    "name": "nokhodian",
    "email": "nokhodian@gmail.com",
    "url": "https://github.com/nokhodian"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/monoes/monomind.git",
    "directory": "packages/@monoes/monobrowse"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
