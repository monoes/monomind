{
  "name": "@monoes/monoplaybook",
  "version": "1.0.1",
  "description": "Multi-transport automation playbooks — browser (CDP), HTTP, CLI, and MCP actions in a unified recipe format",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "automation",
    "playbook",
    "browser-automation",
    "api-automation",
    "mcp",
    "monomind"
  ],
  "author": {
    "name": "nokhodian",
    "email": "nokhodian@gmail.com",
    "url": "https://github.com/nokhodian"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/monoes/monomind.git",
    "directory": "packages/@monoes/monoplaybook"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
