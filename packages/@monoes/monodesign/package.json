{
  "name": "@monoes/monodesign",
  "version": "1.2.0",
  "description": "Frontend design intelligence for AI agents \u2014 design tokens, antipattern detection, and the monodesign skill",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens.css",
    "./engine": "./cli/engine/detect-antipatterns.mjs",
    "./engine/browser": "./cli/engine/detect-antipatterns-browser.js"
  },
  "bin": {
    "monodesign": "cli/bin/cli.js"
  },
  "files": [
    "cli/",
    "skill/",
    "src/",
    "NOTICE.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-strip-types --test 'tests/*.test.*' 'tests/lib/*.test.*'",
    "sync": "node scripts/sync-skill.mjs",
    "prepare": "node scripts/sync-skill.mjs"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "antipattern",
    "frontend",
    "monomind",
    "oklch",
    "ui",
    "ai-agent"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "css-select": "^7.0.0",
    "css-tree": "^3.2.1",
    "domutils": "^4.0.2",
    "fflate": "^0.8.3",
    "htmlparser2": "^12.0.0",
    "marked": "^18.0.0"
  },
  "optionalDependencies": {
    "@monoes/monobrowse": "^1.0.3",
    "puppeteer": "^25.1.0"
  }
}
