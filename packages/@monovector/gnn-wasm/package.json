{
  "name": "@monovector/gnn-wasm",
  "version": "0.1.0",
  "description": "MonoVector GNN WASM — graph neural network in WebAssembly",
  "main": "pkg/monovector_gnn_wasm.js",
  "types": "pkg/monovector_gnn_wasm.d.ts",
  "scripts": {
    "build": "wasm-pack build --target nodejs --out-dir pkg --out-name monovector_gnn_wasm",
    "build:web": "wasm-pack build --target web --out-dir pkg-web --out-name monovector_gnn_wasm",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler --out-name monovector_gnn_wasm"
  },
  "license": "MIT",
  "files": ["pkg/", "src/", "Cargo.toml"]
}
