{
  "name": "@monomind/v1-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Monomind V1 - Modular AI Agent Coordination System",
  "workspaces": [
    "@monomind/*",
    "monomind"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:coverage": "vitest run --coverage",
    "test:coverage:integration": "vitest run __tests__/integration --coverage",
    "test:memory": "pnpm --filter @monomind/memory test",
    "test:swarm": "pnpm --filter @monomind/swarm test",
    "bench": "pnpm --filter @monomind/performance bench",
    "bench:attention": "pnpm --filter @monomind/performance bench:attention",
    "typecheck": "pnpm -r typecheck",
    "clean": "rm -rf node_modules @monomind/*/node_modules monomind/node_modules",
    "publish:dry": "pnpm --filter monomind publish --dry-run --tag alpha --no-git-checks",
    "publish:alpha": "pnpm --filter monomind publish --tag alpha --no-git-checks",
    "version:patch": "pnpm -r exec npm version patch",
    "version:minor": "pnpm -r exec npm version minor",
    "version:major": "pnpm -r exec npm version major",
    "bun:install": "bun install",
    "bun:build": "bun run --filter '*' build",
    "bun:test": "bun test",
    "bun:dev": "bun run --watch src/index.ts",
    "bun:publish:dry": "cd monomind && bun publish --dry-run --tag alpha",
    "bun:publish:alpha": "cd monomind && bun publish --tag alpha"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "4.1.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "neverBuiltDependencies": ["sharp"],
    "overrides": {
      "handlebars": ">=4.7.9"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "@monoes/*",
        "@anthropic-ai/claude-code",
        "lancedb"
      ]
    }
  }
}
