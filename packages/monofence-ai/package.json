{
  "name": "monofence-ai",
  "version": "1.0.0",
  "description": "AI Manipulation Defense System — evasion detection, multi-turn context, output scanning, hook wiring",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./detection": {
      "import": "./dist/domain/services/threat-detection-service.js",
      "types": "./dist/domain/services/threat-detection-service.d.ts"
    },
    "./learning": {
      "import": "./dist/domain/services/threat-learning-service.js",
      "types": "./dist/domain/services/threat-learning-service.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/security-hook.js",
      "types": "./dist/hooks/security-hook.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "lancedb": ">=2.0.0-alpha.1"
  },
  "peerDependenciesMeta": {
    "lancedb": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "ai-security", "prompt-injection", "jailbreak-detection", "evasion-detection",
    "context-tracking", "output-scanning", "monomind", "llm-security"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monoes/monomind.git",
    "directory": "packages/monofence-ai"
  },
  "engines": { "node": ">=18.0.0" }
}
