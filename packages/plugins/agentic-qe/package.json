{
  "name": "@monomind/plugin-agentic-qe",
  "version": "1.0.0",
  "description": "Quality Engineering plugin for Monomind V1 with 51 specialized agents across 12 DDD bounded contexts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "agents",
    "skills",
    "plugin.yaml",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "monomind",
    "plugin",
    "quality-engineering",
    "testing",
    "coverage",
    "tdd",
    "security",
    "chaos-engineering",
    "accessibility",
    "ai-agents"
  ],
  "author": "rUv",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nokhodian/monomind.git",
    "directory": "packages/plugins/agentic-qe"
  },
  "homepage": "https://github.com/nokhodian/monomind/tree/main/packages/plugins/agentic-qe",
  "bugs": {
    "url": "https://github.com/nokhodian/monomind/issues"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@monomind/plugins": "workspace:*",
    "@monomind/memory": "workspace:*",
    "@monomind/security": "workspace:*",
    "@monomind/embeddings": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@monomind/plugins": {
      "optional": true
    },
    "@monomind/memory": {
      "optional": true
    },
    "@monomind/security": {
      "optional": true
    },
    "@monomind/embeddings": {
      "optional": true
    },
    "@monomind/browser": {
      "optional": true
    },
    "@ruvector/attention": {
      "optional": true
    },
    "@ruvector/gnn": {
      "optional": true
    },
    "@ruvector/sona": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
